# Copy to .env.local — never commit real secrets.
# See docs/spec.md for full descriptions.
#
# Vercel (Project → Settings → Environment Variables):
# - Add every variable below for BOTH "Production" and "Preview" (preview URLs do not use Production-only secrets).
# - NEXT_PUBLIC_* must be set before the build so they are inlined into the server/client bundles.
# - After changing env vars, trigger a new deployment (Redeploy).

# Required on Vercel: Production + Preview (and local .env.local).
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=

# Optional: used when NEXT_PUBLIC_SITE_URL is empty (e.g. local-only)
NEXT_PUBLIC_APP_URL=

# Optional: require MFA for admin (set to "true" in production when ready)
# ADMIN_REQUIRE_MFA=true

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
