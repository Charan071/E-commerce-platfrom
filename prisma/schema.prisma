generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USER / AUTH ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  wishlist  WishlistItem[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── ADDRESS ─────────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(uuid())
  userId     String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String  @default("India")
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ─── CATEGORY ────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())

  products Product[]

  @@map("categories")
}

// ─── PRODUCT ─────────────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  discount      String?
  material      String
  sizes         String[] @default([])
  stock         Int      @default(0)
  isNew         Boolean  @default(false)
  isActive      Boolean  @default(true)
  categoryId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category      @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  colors     ProductColor[]
  orderItems OrderItem[]
  reviews    Review[]
  wishlist   WishlistItem[]

  @@index([categoryId])
  @@index([isActive, createdAt])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  publicId  String  // Cloudinary public_id
  isHover   Boolean @default(false)
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductColor {
  id        String @id @default(uuid())
  productId String
  name      String
  hex       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_colors")
}

// ─── WISHLIST ────────────────────────────────────────────────────────────────

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

// ─── ORDER ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @default(cuid())
  userId          String?
  addressId       String?
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?
  paymentId       String?     // Razorpay / Stripe order id
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingPincode String?
  shippingCountry String?     @default("India")
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @db.Decimal(10, 2) @default(0)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user      User?       @relation(fields: [userId], references: [id])
  address   Address?    @relation(fields: [addressId], references: [id])
  items     OrderItem[]

  @@index([userId])
  @@index([addressId])
  @@index([status, createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  title     String  // snapshot at time of order
  imageUrl  String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

// ─── CMS / BRAND / HOMEPAGE CONTENT ──────────────────────────────────────────

model BrandKit {
  id               String   @id @default(cuid())
  brandName        String   @default("AnavaSilks")
  tagline          String   @default("Silk and Sarees")
  voice            String?  @db.Text
  primaryColor     String   @default("#171717")
  secondaryColor   String   @default("#f6f4f0")
  accentColor      String   @default("#8b6a3e")
  surfaceColor     String   @default("#ffffff")
  mutedTextColor   String   @default("#6b6b6b")
  headingFont      String   @default("Playfair Display")
  bodyFont         String   @default("Inter")
  navLetterSpacing String   @default("0.22em")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("brand_kit")
}

model HomeHero {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  ctaLabel      String?  @default("Shop Here")
  ctaHref       String?  @default("/collections")
  imageUrl      String
  imagePublicId String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("home_hero")
}

model CollectionHighlight {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  href          String   @default("/collections")
  imageUrl      String
  imagePublicId String?
  imageHasEmbeddedText Boolean @default(false)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("collection_highlights")
}

model NavPromoBlock {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  href          String   @default("/collections")
  imageUrl      String
  imagePublicId String?
  imageHasEmbeddedText Boolean @default(false)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("nav_promo_blocks")
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  userId    String
  email     String?
  action    String
  target    String
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("newsletter_subscriptions")
}
